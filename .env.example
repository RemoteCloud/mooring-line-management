# Example environment for local development. Copy to .env and fill real values.
# .env is gitignored; this template is committed.

# --- OIDC (Maranics nightly provider) ---
OIDC_ISSUER=https://administration.cloud.maranics-nightly.com/nightly
OIDC_CLIENT_ID=changeme
OIDC_CLIENT_SECRET=changeme
OIDC_REDIRECT_URI=http://localhost:8091/api/auth/callback
OIDC_SCOPES=openid email profile roles offline_access
OIDC_PROMPT=login
# OIDC_ADMIN_GROUP: comma-separated set of UserManagement POSITION ids whose
# holders are admins (full read+write, and manage access control). Compared
# against the user's `position_id` claim from /userinfo. Mirrors the reference
# app's UM_ADMIN_POSITION_IDS; the value below is the seeded "Admin" position.
# All other access is granted per position TEAM from the in-app
# Settings -> Access control page (default: denied).
OIDC_ADMIN_GROUP=0ee848c0-3469-4561-99ad-623d8eb87a7d

# --- Session / token-at-rest encryption ---
# SESSION_SECRET: server secret. In dev, also seeds TOKEN_ENC_KEY if that is unset.
SESSION_SECRET=changeme
# TOKEN_ENC_KEY: base64 of exactly 32 random bytes (AES-256-GCM). Generate with:
#   openssl rand -base64 32
TOKEN_ENC_KEY=

# Public origin (and base path) the browser reaches the app on. Drives the
# cookie Secure flag (https => Secure) and post-login redirects.
APP_BASE_URL=http://localhost:8091
